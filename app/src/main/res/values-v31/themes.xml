<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:dialogTheme">@style/AppDialogTheme</item>
        <item name="android:alertDialogTheme">@style/AppAlertTheme</item>
        <item name="android:colorControlNormal">?attr/colorOnPrimaryContainer</item>
        <item name="android:textAppearance">@style/AppPopupMenuText</item>
        <item name="android:itemTextAppearance">@style/AppPopupMenuText</item>
        <item name="popupMenuStyle">@style/AppPopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/AppPopupMenu</item>
        <item name="actionBarPopupTheme">@style/AppPopupMenuOverlay</item>
    </style>

    <style name="AppDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:windowMinWidthMajor">65%</item>
        <item name="android:windowMinWidthMinor">95%</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppAlertTheme" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="android:textColorAlertDialogListItem">?attr/colorOnSurface</item>
        <item name="android:windowMinWidthMajor">65%</item>
        <item name="android:windowMinWidthMinor">95%</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">?attr/colorPrimary</item>
    </style>

    <style name="Toolbar" parent="ThemeOverlay.Material3.ActionBar">
        <item name="android:textColor">?attr/colorOnPrimaryContainer</item>
        <item name="android:colorControlNormal">?attr/colorOnPrimaryContainer</item>
    </style>

    <style name="AppPopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">?attr/colorSurface</item>
        <item name="android:itemTextAppearance">@style/AppPopupMenuText</item>
    </style>

    <style name="AppPopupMenuText" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppPopupMenuOverlay" parent="ThemeOverlay.Material3.DynamicColors.Dark">
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
</resources>